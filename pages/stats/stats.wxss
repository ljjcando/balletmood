/* 舞者成就统计页样式 */
.stats-container {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 30rpx;
  box-sizing: border-box;
}

/* ==================== 顶部统计卡片 ==================== */
.summary-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.summary-card {
  flex: 1;
  background: #FAF7F2;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.summary-card.main {
  background: #D2B48C;
}

.summary-card.main .summary-value {
  color: #FAF7F2;
}

.summary-card.main .summary-label {
  color: rgba(250, 247, 242, 0.9);
}

.summary-value {
  font-size: 48rpx;
  font-weight: 300;
  color: #D2B48C;
  margin-bottom: 10rpx;
  line-height: 1;
}

.summary-label {
  font-size: 24rpx;
  color: #8B8680;
  text-align: center;
}

/* ==================== 通用区块样式 ==================== */
.section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 28rpx;
  color: #4A4A4A;
  font-weight: 600;
  margin-bottom: 25rpx;
  padding-left: 10rpx;
}

/* ==================== 能量场预留位 ==================== */
.energy-placeholder {
  background: #FAF7F2;
  border-radius: 20rpx;
  padding: 40rpx;
  min-height: 300rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
}

.energy-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.energy-bubble {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.bubble-name {
  font-size: 24rpx;
  color: #4A4A4A;
  margin-bottom: 5rpx;
}

.bubble-count {
  font-size: 32rpx;
  color: #4A4A4A;
  font-weight: 600;
}

/* ==================== 课程统计 ==================== */
.course-stats {
  background: #FAF7F2;
  border-radius: 20rpx;
  padding: 30rpx;
}

.course-stat-item {
  margin-bottom: 25rpx;
}

.course-stat-item:last-child {
  margin-bottom: 0;
}

.course-stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.course-stat-name {
  font-size: 26rpx;
  color: #4A4A4A;
  font-weight: 500;
}

.course-stat-hours {
  font-size: 24rpx;
  color: #8B8680;
}

.course-stat-bar-wrapper {
  width: 100%;
  height: 12rpx;
  background: #E8DDD4;
  border-radius: 6rpx;
  overflow: hidden;
}

.course-stat-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* ==================== 空状态提示 ==================== */
.empty-hint {
  width: 100%;
  text-align: center;
  font-size: 26rpx;
  color: #C9B8A8;
  padding: 60rpx 0;
}
